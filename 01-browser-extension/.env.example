# OmniChat Extension — reference config.
#
# NOTE: A Chrome extension cannot read a .env file. This file documents the
# shared env convention and the exact values you paste into the extension's
# Options page (chrome://extensions -> OmniChat -> Details -> Extension options).
#
# Each line below maps 1:1 to a field in options.html.

# --- Twitch (no API key, anonymous IRC) ---
# Comma-separated channel logins -> Options field "Twitch channels"
TWITCH_CHANNELS=ansemtrades,xqc

# --- Kick (no API key, Pusher) ---
# Comma-separated slugs -> Options field "Kick channels"
KICK_CHANNELS=trainwreckstv
# Optional: comma-separated chatroom IDs aligned to KICK_CHANNELS.
# Only needed if Cloudflare blocks the auto-resolve fetch. -> "Chatroom IDs override"
KICK_CHATROOM_IDS=

# --- X / Twitter (API v2 Basic tier, bearer token, polling) ---
# -> Options field "Bearer Token"
X_BEARER_TOKEN=
# replies | mentions | hashtag  -> Options field "Mode"
X_MODE=hashtag
# conversation_id (replies) / handle (mentions) / tag (hashtag) -> Options "Target"
X_TARGET=crypto

# --- Demo mode ---
# Leave all of the above blank (or tick "Force Demo Mode") to run with a
# synthetic feed from all three sources, zero config.
DEMO=1
