# ---- OmniChat Cloud env ----
# SQLite file db (zero setup). Leave as-is.
DATABASE_URL="file:./dev.db"

# Demo mode: 1 = inject synthetic messages for the auto-created demo room.
# A room with no real targets always falls back to demo regardless.
DEMO=1

# ---- Default targets used ONLY for the auto-created demo room ----
# (Each room you create in the UI carries its own per-room config in the db.)
# Twitch logins, comma-separated (anonymous IRC, no key needed)
TWITCH_CHANNELS=
# Kick channel slugs, comma-separated (no key needed)
KICK_CHANNELS=
# Optional: pre-resolved Kick chatroom ids aligned to KICK_CHANNELS (skips the Cloudflare lookup)
KICK_CHATROOM_IDS=

# ---- X / Twitter (polling, optional) ----
# X API v2 Basic-tier bearer token. If absent, X is skipped (no crash).
X_BEARER_TOKEN=
# replies | mentions | hashtag
X_MODE=hashtag
# conversation id (replies) / handle (mentions) / tag without # (hashtag)
X_TARGET=bitcoin

# Next.js dev server port
PORT=3000
