# OmniChat Hub — copy to .env (or rely on the shared ../.env). All optional: with NOTHING
# set, the server runs in DEMO MODE and streams synthetic Twitch/X/Kick messages.

# --- X / Twitter (API v2, polling) ---
# Bearer token for api.twitter.com. If absent, the X connector is skipped (no crash).
X_BEARER_TOKEN=
# replies | mentions | hashtag
X_MODE=mentions
# conversation id (replies) | handle without @ (mentions) | tag without # (hashtag)
X_TARGET=blknoiz06

# --- Twitch (anonymous IRC, no key) ---
# comma-separated channel logins, no leading '#'
TWITCH_CHANNELS=ansem,xqc

# --- Kick (Pusher, no key) ---
# comma-separated channel slugs
KICK_CHANNELS=ansem,trainwreckstv
# Optional: hard-set chatroom ids (comma list aligned to KICK_CHANNELS) if Cloudflare blocks lookup
# KICK_CHATROOM_IDS=123456,789012

# --- Server ---
PORT=3848

# Force demo mode even if channels are configured (set to 1)
DEMO=
