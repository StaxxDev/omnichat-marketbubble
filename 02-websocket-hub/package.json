{
  "name": "omnichat-hub",
  "version": "1.0.0",
  "private": true,
  "description": "Unified chat aggregator — Twitch + X + Kick in one real-time WebSocket feed.",
  "scripts": {
    "dev": "concurrently -k -n SERVER,WEB -c magenta,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node server/index.js",
    "dev:web": "npm --prefix web run dev",
    "build": "npm --prefix web install && npm --prefix web run build",
    "start": "node server/index.js",
    "postinstall": "npm --prefix web install"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
