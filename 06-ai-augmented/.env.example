# OmniChat AI — configuration. Copy to .env and fill in. ALL optional:
# with nothing set (or DEMO=1) the app runs in DEMO MODE out of the box.

# ---- AI layer (optional) -------------------------------------------------
# If set, each message gets a spam/toxicity flag + sentiment emoji, and a
# rolling "what is chat talking about" banner refreshes every ~15s.
# If UNSET, the app degrades gracefully and runs as a plain aggregator.
ANTHROPIC_API_KEY=

# ---- Twitch (anonymous IRC — NO API KEY) ---------------------------------
# Comma-separated channel logins (no leading #).
TWITCH_CHANNELS=blknoiz06,xqc

# ---- Kick (Pusher — NO API KEY) ------------------------------------------
# Comma-separated channel slugs. If Cloudflare blocks the chatroom-id lookup,
# hard-set ids below, aligned positionally to KICK_CHANNELS.
KICK_CHANNELS=trainwreckstv,xqc
# KICK_CHATROOM_IDS=

# ---- X / Twitter (API v2 recent-search polling — bearer token) -----------
X_BEARER_TOKEN=
# X_MODE: replies | mentions | hashtag
X_MODE=mentions
# X_TARGET: conversation id (replies) / handle (mentions) / tag (hashtag)
X_TARGET=blknoiz06

# ---- Server --------------------------------------------------------------
PORT=8787

# Force demo mode even if channels are configured:
# DEMO=1
