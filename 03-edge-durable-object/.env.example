# OmniChat Edge — configuration
#
# On Cloudflare Workers, NON-SECRET values live in wrangler.toml under [vars]
# and the SECRET (X bearer token) is set with:
#     wrangler secret put X_BEARER_TOKEN
#
# This .env.example documents every knob. For local `wrangler dev` you can also
# put these in a `.dev.vars` file (same KEY=VALUE format) and wrangler will load
# them automatically. Copy this file to `.dev.vars` to use it that way.

# --- Twitch (anonymous IRC, no API key needed) ---
# Comma-separated channel logins, lowercase.
TWITCH_CHANNELS=ansem,xqc

# --- Kick (Pusher, no API key needed) ---
# Comma-separated channel slugs.
KICK_CHANNELS=trainwreckstv,xqc
# Optional: comma-separated chatroom ids aligned to KICK_CHANNELS, used only if
# kick.com's channel API is blocked by Cloudflare in your region.
KICK_CHATROOM_IDS=

# --- X / Twitter (API v2 Basic tier, POLLING) ---
# SECRET — do NOT commit. Set via: wrangler secret put X_BEARER_TOKEN
X_BEARER_TOKEN=
# replies | mentions | hashtag
X_MODE=hashtag
# conversation id (replies) / handle without @ (mentions) / tag without # (hashtag)
X_TARGET=crypto

# --- Demo mode ---
# "1" forces synthetic messages from all three sources even if channels are set.
# If nothing above is configured, demo mode turns on automatically.
DEMO=
