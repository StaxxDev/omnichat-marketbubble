# ============================================================
# OmniChat Bridge — .env.example
# Copy to ".env" and fill in what you want. EVERYTHING is optional:
# with nothing set, the app runs in DEMO MODE (synthetic feed).
# ============================================================

# --- Web server ---
PORT=8088

# Force the synthetic demo feed even if channels are configured (1 = on)
DEMO=

# ============================================================
# SOURCES
# ============================================================

# --- Twitch (anonymous, NO API key) ---
# CSV of channel logins (lowercase). e.g. xqc,kaicenat,jynxzi
TWITCH_CHANNELS=

# --- Kick (NO API key) ---
# CSV of channel slugs. e.g. xqc,trainwreckstv
KICK_CHANNELS=
# Optional: if Kick's API is Cloudflare-blocked (403), supply chatroom ids
# aligned 1:1 with KICK_CHANNELS above. e.g. 668,12826
KICK_CHATROOM_IDS=

# --- X / Twitter (API v2, needs a bearer token; POLLED every ~12s) ---
X_BEARER_TOKEN=
# replies | mentions | hashtag
X_MODE=hashtag
# the conversation id (replies) / handle without @ (mentions) / tag without # (hashtag)
X_TARGET=

# ============================================================
# OUTBOUND SINKS (both optional & independent)
# ============================================================

# --- Telegram (Bot API). Need BOTH the bot token and a chat id. ---
# Create a bot with @BotFather; get chat id by messaging the bot then
# hitting https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Discord webhook URL (Server Settings -> Integrations -> Webhooks) ---
DISCORD_WEBHOOK_URL=
