# OmniChat Desktop — local config. Copy to ".env" (all OPTIONAL — blank = Demo Mode).
# These are read at launch; you can also edit everything live in the in-app Settings (gear icon),
# which persists to userData/omnichat-settings.json on your machine.

# --- Twitch (anonymous IRC, NO key needed) ---
# csv of channel logins (lowercase)
TWITCH_CHANNELS=ansem,xqc

# --- Kick (Pusher, NO key needed) ---
# csv of channel slugs
KICK_CHANNELS=trainwreckstv
# Optional: csv of chatroom ids aligned to KICK_CHANNELS.
# Only needed if Kick's Cloudflare blocks the slug->id lookup.
KICK_CHATROOM_IDS=

# --- X / Twitter (API v2, bearer token, POLLING every ~12s) ---
# If blank, the X feed is simply skipped (app still runs).
X_BEARER_TOKEN=
# mode: hashtag | mentions | replies
X_MODE=hashtag
# target: the #tag, @handle, or conversation_id depending on mode
X_TARGET=bitcoin

# --- Demo mode ---
# DEMO=1 forces the synthetic feed even when channels are configured.
DEMO=
