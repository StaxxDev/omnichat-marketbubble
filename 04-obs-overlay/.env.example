# OmniChat Overlay — only needed if you want the X (Twitter) feed and/or
# the same-origin proxy URL for OBS. Twitch + Kick + demo run with NO env.
# Copy this to ".env" and fill in. (x-proxy.js auto-loads .env.)

# X / Twitter API v2 bearer token (Basic tier). Leave blank to skip X.
X_BEARER_TOKEN=

# X feed mode: replies | mentions | hashtag
X_MODE=hashtag
# Target for the mode:
#   replies  -> a conversation/tweet id
#   mentions -> a handle without @  (e.g. blknoiz06)
#   hashtag  -> a tag without #     (e.g. SOL)
X_TARGET=SOL

# Port the proxy listens on (also serves overlay.html).
PORT=8787

# OPTIONAL: hard-set Kick chatroom ids if the slug lookup gets CF-blocked.
# Format: "slug:id,slug2:id2"  (e.g. "xqc:668,trainwreckstv:1689")
# KICK_CHATROOM_IDS=
