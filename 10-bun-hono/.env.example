# ───────────────────────────────────────────────────────────────────────────
# OmniChat Lite — environment config
# Copy this file to ".env" and fill in what you want. Bun auto-loads .env.
# Leave EVERYTHING blank to run in DEMO MODE (zero config, synthetic messages).
# ───────────────────────────────────────────────────────────────────────────

# HTTP/WebSocket port (default 8787)
PORT=8787

# Force demo mode even when channels are set (1 = on). Leave blank for auto.
DEMO=

# ── TWITCH (anonymous IRC, NO API KEY) ──────────────────────────────────────
# Comma-separated channel logins (lowercase). Multiple channels supported.
TWITCH_CHANNELS=ansem,xqc

# ── KICK (Pusher WebSocket, NO API KEY) ─────────────────────────────────────
# Comma-separated channel slugs. Multiple channels supported.
KICK_CHANNELS=trainwreckstv,adin
# Optional: if Kick's API 403s behind Cloudflare, hard-code chatroom ids here,
# aligned 1:1 with KICK_CHANNELS above (same order). Find via the /api/v2 call.
KICK_CHATROOM_IDS=

# ── X / TWITTER (API v2 recent-search polling, BEARER TOKEN) ────────────────
# Bearer token from your X developer app (Basic tier or higher).
X_BEARER_TOKEN=
# Mode: replies | mentions | hashtag
X_MODE=hashtag
# Target meaning depends on mode:
#   replies  -> a tweet/conversation id (streams replies to that thread)
#   mentions -> a handle WITHOUT @ (streams tweets mentioning it)
#   hashtag  -> a tag WITHOUT # (streams tweets using it)
X_TARGET=solana
