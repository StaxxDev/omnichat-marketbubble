# ── OmniChat Go ── copy to .env (or just `set` these in your shell) ──
# Leave everything blank to run in DEMO MODE (synthetic messages, zero config).

# Force demo mode even if channels are configured (1 = on)
DEMO=

# HTTP port for the UI + SSE endpoint
PORT=8080

# Max messages retained in the hub history buffer (default 500)
MAX_MESSAGES=500

# ── Twitch (anonymous IRC, no API key) ──
# CSV of channel logins (lowercase), e.g. blknoiz06,xqc,hasanabi
TWITCH_CHANNELS=

# ── Kick (Pusher, no API key) ──
# CSV of channel slugs, e.g. ansem,trainwreckstv
KICK_CHANNELS=
# Optional: CSV of chatroom ids aligned to KICK_CHANNELS, used if Kick's
# Cloudflare blocks server-side slug resolution (403). e.g. 123456,789012
KICK_CHATROOM_IDS=

# ── X / Twitter (API v2, polling) ──
# Bearer token for X API v2 (Basic tier or higher)
X_BEARER_TOKEN=
# replies | mentions | hashtag
X_MODE=mentions
# conversation id (replies) / handle without @ (mentions) / tag without # (hashtag)
X_TARGET=
